# Normalize line endings to LF in the repo, checkout as-is on all platforms
* text=auto eol=lf

# Force LF for shell scripts (must not be CRLF on Linux/macOS)
*.sh   text eol=lf
*.py   text eol=lf

# Force CRLF for Windows-specific files
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary files — no line ending conversion
*.png  binary
*.ico  binary
*.icns binary
*.dmg  binary
*.exe  binary
