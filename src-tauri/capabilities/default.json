{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Foundry desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-unminimize",
    "core:window:allow-maximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-start-dragging",
    "workspace-core",
    "shell:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/signalos-python", "sidecar": true, "args": true }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/signalos-python", "sidecar": true, "args": true }
      ]
    },
    "process:default",
    "updater:default",
    "notification:default",
    "fs:default",
    "fs:allow-mkdir",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$APPDATA/**" },
        { "path": "$LOCALAPPDATA/**" }
      ]
    },
    "dialog:default",
    "opener:default"
  ]
}
