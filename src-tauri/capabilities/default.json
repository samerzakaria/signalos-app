{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for SignalOS desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/signalos-python", "sidecar": true, "args": true }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/signalos-python", "sidecar": true, "args": true }
      ]
    },
    "process:default",
    "updater:default",
    "notification:default",
    "fs:default",
    "dialog:default",
    "opener:default"
  ]
}
