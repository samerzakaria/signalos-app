{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SignalOS",
  "version": "0.0.7",
  "identifier": "com.signalos.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SignalOS",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "center": true,
        "transparent": false,
        "titleBarStyle": "Visible",
        "hiddenTitle": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": ["bin/signalos-python"],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "dmg": {
        "background": null,
        "windowPosition": { "x": 400, "y": 100 },
        "windowSize": { "width": 660, "height": 400 }
      },
      "entitlements": "entitlements.plist"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "linux": {
      "deb": { "depends": [] },
      "appimage": { "bundleMediaFramework": false }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERFMENBN0E5ODJDRTZGQzIKUldUQ2I4NkNxYWNNM2lkSk8wb1l5SHZUR0Y2UVRNUDBneXFrNUQvdXVBYXh6emtQWTlBR2FlOEoK",
      "endpoints": [
        "https://raw.githubusercontent.com/samerzakaria/signalos-app/main/distribution/update-manifest/beta.json",
        "https://raw.githubusercontent.com/samerzakaria/signalos-app/main/distribution/update-manifest/latest.json"
      ]
    }
  }
}
