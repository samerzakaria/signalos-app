{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SignalOS",
  "version": "3.0.0-internal.5",
  "identifier": "com.signalos.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SignalOS",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "center": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: blob:; script-src 'self'; frame-src http://localhost:* http://127.0.0.1:*; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost ws://localhost:* ws://127.0.0.1:* http://localhost:* http://127.0.0.1:* https://samerzakaria.github.io"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": ["bin/signalos-python"],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "dmg": {
        "background": null,
        "windowPosition": { "x": 400, "y": 100 },
        "windowSize": { "width": 660, "height": 400 }
      },
      "entitlements": "entitlements.plist"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "wix": {
        "version": "3.0.0.5"
      }
    },
    "linux": {
      "deb": { "depends": [] },
      "appimage": { "bundleMediaFramework": false }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERFMENBN0E5ODJDRTZGQzIKUldUQ2I4NkNxYWNNM2lkSk8wb1l5SHZUR0Y2UVRNUDBneXFrNUQvdXVBYXh6emtQWTlBR2FlOEoK",
      "endpoints": [
        "https://samerzakaria.github.io/signalos-app/update-manifest/beta.json",
        "https://samerzakaria.github.io/signalos-app/update-manifest/latest.json"
      ]
    }
  }
}
