# Rust / Cargo
target/
Cargo.lock

# Tauri
src-tauri/target/
.tauri/

# Node
node_modules/
dist/
.vite/

# Python
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# Env / secrets — NEVER commit these
.env
.env.*
*.key
*.pem
*.p12
*.pfx

# IDE
.vscode/settings.json
.idea/
*.iml

# Build outputs
dist-tauri/
bundle/
release/

# Logs
*.log
npm-debug.log*

# Signing artifacts — generated at build time, not stored in repo
src-tauri/gen/
src-tauri/bin/
.sidecar-venv/

# Claude Code — per-developer permission allow-list (machine-specific)
.claude/settings.local.json

# Internal build attestations — per-builder pipeline metadata, not for repo
distribution/internal/

# Per-workspace local state — generated by signal-init / orchestrate;
# not protocol content. The .signalos/ tree mixes ship-with-bundle docs
# (which DO belong in repo) with per-run state (which doesn't), so we
# enumerate the local-only artefacts here instead of ignoring the whole
# directory.
.signalos/AUDIT_TRAIL.jsonl
.signalos/wave-checkpoints/
.signalos/sandbox.json
.signalos/missing-deps.json
.signalos/sessions/
.signalos/plans/retry-*.yaml
.signalos/worktree-state.json
.signalos/worktrees/
