#!/usr/bin/env bash
# post-retro — Constitution Delta + Tamper-Evidence Hook
#
# Enforces Constitution Preamble Law 3 ("Every retro produces a Constitution
# delta. Silence is not permitted.") and §10.3 (tamper-evidence via hash
# recording in AMENDMENTS.md).
#
# Runs after Phase-8 retro is complete. Verifies a delta exists for this
# Wave, records the Constitution hash if an amendment was made.
#
# Arguments:
#   $1 = Wave ID (e.g. wave-03-checkout)

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

ERRORS=0
WAVE_ID="${1:?Usage: post-retro <wave-id>}"
REPO_ROOT=$(git rev-parse --show-toplevel)

echo "post-retro hook — Wave $WAVE_ID"

# ─── Rule 1: Retro artifact must exist ──────────────────────────────────────
RETRO_DIR="$REPO_ROOT/waves/$WAVE_ID"
RETRO_FILE="$RETRO_DIR/review.md"
if [ ! -f "$RETRO_FILE" ]; then
  echo -e "${RED}✗ BLOCKED: Retro artifact not found at $RETRO_FILE${NC}"
  echo "  Phase-8 retro must produce waves/$WAVE_ID/review.md"
  ERRORS=$((ERRORS + 1))
fi

# ─── Rule 2: Constitution delta must be present ─────────────────────────────
AMENDMENTS_FILE="$REPO_ROOT/core/governance/Retro/AMENDMENTS.md"
if [ ! -f "$AMENDMENTS_FILE" ]; then
  echo -e "${RED}✗ BLOCKED: AMENDMENTS.md not found at core/governance/Retro/AMENDMENTS.md${NC}"
  ERRORS=$((ERRORS + 1))
else
  if ! grep -qE "Wave:\s*$WAVE_ID" "$AMENDMENTS_FILE"; then
    echo -e "${RED}✗ BLOCKED: No Constitution delta recorded for Wave $WAVE_ID in AMENDMENTS.md${NC}"
    echo "  Constitution Preamble Law 3: 'Every retro produces a Constitution delta."
    echo "   Either a ratified amendment, or a signed no-change record. Silence is not permitted.'"
    echo ""
    echo "  Append one of the following to AMENDMENTS.md:"
    echo ""
    echo "  Wave: $WAVE_ID"
    echo "  Type: amendment"
    echo "  Summary: <one-line description>"
    echo "  Delta PR: <link>"
    echo "  PO signature: <name> <date>"
    echo "  PE signature: <name> <date>"
    echo ""
    echo "  OR:"
    echo ""
    echo "  Wave: $WAVE_ID"
    echo "  Type: no-change"
    echo "  Rationale: <why this wave surfaced no constitutional lesson>"
    echo "  PO signature: <name> <date>"
    echo "  PE signature: <name> <date>"
    ERRORS=$((ERRORS + 1))
  fi
fi

# ─── Rule 3: If an amendment was ratified, record Constitution hash ─────────
CONSTITUTION_FILE="$REPO_ROOT/core/governance/Governance/CONSTITUTION.md"
if [ -f "$CONSTITUTION_FILE" ] && [ -f "$AMENDMENTS_FILE" ]; then
  # Check if this Wave's entry is type: amendment
  AMENDMENT_BLOCK=$(awk -v wave="$WAVE_ID" '
    /^Wave:/ {in_block = 0}
    $0 ~ "Wave:[[:space:]]*" wave {in_block = 1}
    in_block {print}
  ' "$AMENDMENTS_FILE")

  if echo "$AMENDMENT_BLOCK" | grep -qE 'Type:\s*amendment'; then
    HASH=$(sha256sum "$CONSTITUTION_FILE" | awk '{print $1}')
    HASH_LINE="Constitution-hash-after: $HASH"

    if ! echo "$AMENDMENT_BLOCK" | grep -q "$HASH_LINE"; then
      echo -e "${YELLOW}⚠ Recording Constitution hash for ratified amendment...${NC}"
      # Append hash line to the block
      HASH_RECORD_FILE="$REPO_ROOT/core/governance/Retro/.constitution-hashes.log"
      mkdir -p "$(dirname "$HASH_RECORD_FILE")"
      echo "$WAVE_ID $HASH $(date -u +%Y-%m-%dT%H:%M:%SZ)" >> "$HASH_RECORD_FILE"
      echo "  Recorded: Wave $WAVE_ID → hash $HASH"
      echo -e "${YELLOW}  Append the following to AMENDMENTS.md under this Wave's block:${NC}"
      echo "    $HASH_LINE"
    fi
  fi
fi

# ─── Rule 4: PO + PE both signed ────────────────────────────────────────────
if [ -f "$AMENDMENTS_FILE" ] && [ -n "${AMENDMENT_BLOCK:-}" ]; then
  if ! echo "$AMENDMENT_BLOCK" | grep -qiE 'PO[[:space:]]+signature:'; then
    echo -e "${RED}✗ BLOCKED: PO signature missing on delta for Wave $WAVE_ID${NC}"
    ERRORS=$((ERRORS + 1))
  fi
  if ! echo "$AMENDMENT_BLOCK" | grep -qiE 'PE[[:space:]]+signature:'; then
    echo -e "${RED}✗ BLOCKED: PE signature missing on delta for Wave $WAVE_ID${NC}"
    ERRORS=$((ERRORS + 1))
  fi
fi

# ─── Summary ────────────────────────────────────────────────────────────────
if [ $ERRORS -gt 0 ]; then
  echo ""
  echo -e "${RED}✗ post-retro blocked. Fix $ERRORS error(s) above.${NC}"
  echo ""
  echo "PROTOCOL VIOLATION: Phase-8 retro delta missing for Wave $WAVE_ID."
  echo "This blocks the next Wave's Gate 1."
  exit 1
fi

echo -e "${GREEN}✓ post-retro checks passed. Constitution delta recorded for Wave $WAVE_ID.${NC}"
exit 0
