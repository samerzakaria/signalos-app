description: Use signalos handoff before transferring operator ownership.
globs: [".signalos/handoff/**", ".signalos/product/CLOSEOUT.json", ".signalos/AUDIT_TRAIL.jsonl", ".signalos/deploy/**"]
alwaysApply: false
