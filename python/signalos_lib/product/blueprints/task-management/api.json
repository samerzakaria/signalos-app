{
  "routes": [
    {
      "method": "POST",
      "path": "/tasks",
      "description": "Create a new task",
      "request": {"title": "string", "description": "string", "project_id": "string", "assignee": "string?", "due_date": "string?"},
      "response": {"id": "string", "title": "string", "status": "open"}
    },
    {
      "method": "GET",
      "path": "/tasks",
      "description": "List tasks with optional filters",
      "query": {"project_id": "string?", "status": "string?", "assignee": "string?"},
      "response": {"tasks": "Task[]", "total": "number"}
    },
    {
      "method": "PATCH",
      "path": "/tasks/:id",
      "description": "Update a task",
      "request": {"title": "string?", "description": "string?", "status": "string?", "assignee": "string?", "due_date": "string?"},
      "response": {"id": "string", "title": "string", "status": "string"}
    },
    {
      "method": "DELETE",
      "path": "/tasks/:id",
      "description": "Delete a task",
      "response": {"deleted": "boolean"}
    },
    {
      "method": "POST",
      "path": "/projects",
      "description": "Create a new project",
      "request": {"name": "string", "description": "string"},
      "response": {"id": "string", "name": "string"}
    },
    {
      "method": "GET",
      "path": "/projects",
      "description": "List all projects",
      "response": {"projects": "Project[]", "total": "number"}
    },
    {
      "method": "GET",
      "path": "/team-members",
      "description": "List team members with capacity and role metadata",
      "query": {"team_id": "string?", "role": "string?"},
      "response": {"members": "TeamMember[]", "total": "number"}
    },
    {
      "method": "GET",
      "path": "/workload",
      "description": "Summarize workload and utilization by team member",
      "query": {"team_id": "string?", "period": "string?"},
      "response": {"snapshots": "WorkloadSnapshot[]", "overloaded": "TeamMember[]"}
    },
    {
      "method": "GET",
      "path": "/kpis",
      "description": "Return KPI metrics for teams, members, and projects",
      "query": {"scope": "string?", "period": "string?"},
      "response": {"metrics": "KpiMetric[]", "summary": "object"}
    },
    {
      "method": "GET",
      "path": "/reports/management",
      "description": "Export management report for tasks, workload, utilization, and KPIs",
      "query": {"team_id": "string?", "period": "string?"},
      "response": {"report_url": "string", "generated_at": "string"}
    }
  ]
}
