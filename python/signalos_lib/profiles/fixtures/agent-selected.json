{
  "schema_version": 1,
  "id": "agent-selected",
  "name": "Agent-selected Technology",
  "description": "Technology-neutral profile for user or agent selected stacks that do not yet have a native greenfield shell.",
  "required_templates": [
    {
      "source": "core/governance/Governance/SOUL-DOCUMENT.md",
      "destination": "core/governance/Governance/SOUL-DOCUMENT.md",
